{
  "$schema": "https://schema.tauri.app/config/1.5.0",
  "build": {
    "beforeDevCommand": "C:\\nvm4w\\nodejs\\node.exe E:\\PATRINS\\patrins-oneclick\\node_modules\\vite\\bin\\vite.js",
    "beforeBuildCommand": "C:\\nvm4w\\nodejs\\npm.cmd run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Patrins OneClick Reset",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "fs": {
        "all": true,
        "scope": ["$APPDATA/*", "$LOCALAPPDATA/*", "$HOME/*", "$DESKTOP/*", "$DOCUMENT/*", "$DOWNLOAD/*", "$PICTURE/*", "$VIDEO/*"]
      },
      "path": {
        "all": true
      },
      "notification": {
        "all": true
      },
      "dialog": {
        "all": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.patrins.oneclick",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://oneclick.patrins.com/api/updates/{{target}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "TO_BE_GENERATED"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Patrins OneClick Reset",
        "width": 900,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "fileDropEnabled": false
      }
    ]
  }
}
